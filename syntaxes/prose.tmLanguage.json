{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OpenProse",
  "scopeName": "source.prose",
  "patterns": [
    { "include": "#comment" },
    { "include": "#discretion-multiline" },
    { "include": "#discretion-single" },
    { "include": "#string-triple" },
    { "include": "#string-single" },
    { "include": "#agent-definition" },
    { "include": "#block-definition" },
    { "include": "#input-declaration" },
    { "include": "#output-declaration" },
    { "include": "#variable-declaration" },
    { "include": "#keywords" },
    { "include": "#properties" },
    { "include": "#constants" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.prose",
      "match": "#.*$"
    },
    "discretion-multiline": {
      "name": "markup.italic.discretion.multiline.prose",
      "begin": "\\*\\*\\*",
      "end": "\\*\\*\\*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.discretion.begin.prose" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.discretion.end.prose" }
      }
    },
    "discretion-single": {
      "name": "markup.italic.discretion.prose",
      "match": "\\*\\*(?:[^*]|\\*(?!\\*))+\\*\\*"
    },
    "string-triple": {
      "name": "string.quoted.triple.prose",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.prose" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.prose" }
      },
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation" }
      ]
    },
    "string-single": {
      "name": "string.quoted.double.prose",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.prose" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.prose" }
      },
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation" }
      ]
    },
    "string-escape": {
      "name": "constant.character.escape.prose",
      "match": "\\\\[\\\\\"nt]"
    },
    "string-interpolation": {
      "name": "constant.other.placeholder.prose",
      "match": "\\{[a-zA-Z_][a-zA-Z0-9_-]*\\}"
    },
    "agent-definition": {
      "match": "^(\\s*)(agent)(\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)(\\s*:)",
      "captures": {
        "2": { "name": "keyword.control.agent.prose" },
        "4": { "name": "entity.name.type.agent.prose" }
      }
    },
    "block-definition": {
      "match": "^(\\s*)(block)(\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)(?:\\([^)]*\\))?(\\s*:)",
      "captures": {
        "2": { "name": "keyword.control.block.prose" },
        "4": { "name": "entity.name.function.block.prose" }
      }
    },
    "input-declaration": {
      "match": "^(\\s*)(input)(\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)(\\s*:)",
      "captures": {
        "2": { "name": "keyword.control.input.prose" },
        "4": { "name": "variable.other.input.prose" }
      }
    },
    "output-declaration": {
      "match": "^(\\s*)(output)(\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)(\\s*=)",
      "captures": {
        "2": { "name": "keyword.control.output.prose" },
        "4": { "name": "variable.other.output.prose" }
      }
    },
    "variable-declaration": {
      "match": "^(\\s*)(let|const)(\\s+)([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captures": {
        "2": { "name": "keyword.control.declaration.prose" },
        "4": { "name": "variable.other.prose" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.prose",
          "match": "\\b(if|elif|else|for|parallel|loop|until|do|in|choice|option|try|catch|finally|throw|include)\\b"
        },
        {
          "name": "keyword.control.session.prose",
          "match": "\\b(session|resume)\\b"
        }
      ]
    },
    "properties": {
      "match": "^(\\s*)(model|prompt|context|tools|persist|retry|backoff|session|resume)(\\s*:)",
      "captures": {
        "2": { "name": "support.type.property-name.prose" }
      }
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.prose",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.model.prose",
          "match": "\\b(sonnet|opus|haiku)\\b"
        },
        {
          "name": "constant.language.permission.prose",
          "match": "\\b(allow|deny)\\b"
        },
        {
          "name": "constant.language.backoff.prose",
          "match": "\\b(none|linear|exponential)\\b"
        },
        {
          "name": "constant.numeric.integer.prose",
          "match": "\\b[0-9]+\\b"
        }
      ]
    }
  }
}
